# App (runtime): no Neon, use a URL do POOLER (host com "-pooler").
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# Conexão DIRETA (host SEM "-pooler"): exigida pelo schema.prisma (directUrl) e
# usada só por `prisma migrate`/`db execute`. O pooler não suporta os locks/DDL
# da migration engine.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
PORT=4000
NODE_ENV="development"

# CORS allowlist (comma-separated origins). Leave empty in dev to reflect any
# origin; ALWAYS set this in production, e.g. "https://app.seudominio.com".
# Inclua também a origem da LANDING PAGE, que chama POST /trial/signup de outro
# domínio: "https://app.seudominio.com,https://seudominio.com".
CORS_ORIGINS=""

# Operator-only secret for internal endpoints (module permissions, tenant seed).
INTERNAL_ADMIN_SECRET=""

# Public URL of the frontend (used for attendant invite links and, quando o
# Tenant.app_url não está setado, para o link mágico do teste grátis).
FRONTEND_URL="http://localhost:5173"

# Tick dos schedulers de fundo (lembretes de agendamento + ciclo de vida do
# trial, que pega carona no mesmo tick). Padrão: 30min.
# CUIDADO COM O CUSTO: no Neon, cada passada que consulta o banco mantém o
# compute ligado por toda a janela de autosuspend. Um tick MENOR que essa janela
# reseta o relógio antes de ele vencer e o banco nunca dorme — foi o que
# aconteceu com o antigo default de 5min contra um autosuspend de 5min.
# A janela do lembrete é medida em horas (reminder_hours_before), então atrasar
# a passada em dezenas de minutos não muda o que o cliente recebe.
BOOKING_REMINDER_INTERVAL_MS=1800000

# Ciclo de vida do teste grátis (avisa 1 dia antes, expira/bloqueia no
# vencimento, re-tenta link não entregue). Padrão: 1h. A granularidade do trial
# é dia, então não adianta baixar muito. Arredondado para o múltiplo mais
# próximo de BOOKING_REMINDER_INTERVAL_MS (roda a cada N passadas daquele tick).
TRIAL_LIFECYCLE_INTERVAL_MS=3600000

SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# WAHA Orchestrator (servico irmao MBC em ../WahaOrchestrator).
# Em dev o MBC sobe em :4011 (o DKW ocupa :4010 no mesmo host). Em prod, :4010.
WAHA_ORCHESTRATOR_URL="http://localhost:4011"
# Deve ser IGUAL ao ORCHESTRATOR_API_KEY do WahaOrchestrator/.env.
WAHA_ORCHESTRATOR_API_KEY=""

# URL publica do Backend acessivel pelos containers WAHA (Docker -> host).
# Win/Mac com Docker Desktop: host.docker.internal resolve o host.
BACKEND_PUBLIC_URL="http://host.docker.internal:4000"
# Secret no header x-webhook-secret que os workers WAHA enviam ao backend.
# Backend rejeita webhooks sem esse header (fail-closed em producao).
WHATSAPP_WEBHOOK_SECRET=""

# Assistente de IA (Groq - https://console.groq.com/keys)
# A chave fica SOMENTE no backend, nunca no frontend.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Armazenamento de imagens (bucket S3-compativel: Railway/MinIO/R2/S3).
# Upload de foto da empresa, atendente e servico. Sem essas vars o endpoint
# /api/uploads responde "Armazenamento nao configurado" (o resto funciona).
# Em dev, aponte para um MinIO local (docker run ... bitnamilegacy/minio).
S3_ENDPOINT="https://SEU-BUCKET.up.railway.app"
S3_REGION="us-east-1"
S3_BUCKET="agendapro"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# path-style e obrigatorio para MinIO/Railway (bucket no path, nao no host).
S3_FORCE_PATH_STYLE="true"
# base publica das imagens; para MinIO path-style = <endpoint>/<bucket>.
S3_PUBLIC_URL="https://SEU-BUCKET.up.railway.app/agendapro"
